{
  "api": {
    "name": "Library Management System API",
    "version": "v1",
    "baseUrl": "/api/v1",
    "authentication": "JWT Bearer Token",
    "roles": ["USER", "ADMIN"]
  },
  "standardResponse": {
    "description": "All responses are wrapped in ApiResponse<T>",
    "schema": {
      "code": "integer (4-digit custom code)",
      "message": "string",
      "result": "T (generic payload, null for delete)"
    }
  },
  "statusCodes": [
    { "scenario": "Success",                  "httpStatus": 200, "code": 1000 },
    { "scenario": "User already exists",      "httpStatus": 400, "code": 1002 },
    { "scenario": "Validation error",         "httpStatus": 400, "code": 1003 },
    { "scenario": "User not found",           "httpStatus": 404, "code": 1005 },
    { "scenario": "Unauthenticated",          "httpStatus": 401, "code": 1006 },
    { "scenario": "Unauthorized (wrong role)","httpStatus": 403, "code": 1007 }
  ],
  "dtos": {
    "request": {
      "UserCreationRequest": {
        "username": "string",
        "password": "string",
        "firstName": "string",
        "lastName": "string",
        "dob": "string (ISO 8601 date)"
      },
      "UserUpdateRequest": {
        "password": "string",
        "firstName": "string",
        "lastName": "string",
        "dob": "string (ISO 8601 date)"
      },
      "AuthenticationRequest": {
        "username": "string",
        "password": "string"
      },
      "IntrospectRequest": {
        "token": "string"
      }
    },
    "response": {
      "UserResponse": {
        "id": "string",
        "username": "string",
        "firstName": "string",
        "lastName": "string",
        "dob": "string (ISO 8601 date)",
        "roles": ["string"]
      },
      "AuthenticationResponse": {
        "token": "string",
        "authenticated": "boolean"
      },
      "IntrospectResponse": {
        "valid": "boolean"
      }
    }
  },
  "endpoints": [
    {
      "feature": "Register Account",
      "method": "POST",
      "url": "/api/v1/users",
      "auth": "Public",
      "requestBody": "UserCreationRequest",
      "responsePayload": "UserResponse",
      "httpStatus": 200,
      "example": {
        "request": {
          "username": "johndoe",
          "password": "secret123",
          "firstName": "John",
          "lastName": "Doe",
          "dob": "1995-08-15"
        },
        "response": {
          "code": 1000,
          "message": "Success",
          "result": {
            "id": "a1b2c3d4",
            "username": "johndoe",
            "firstName": "John",
            "lastName": "Doe",
            "dob": "1995-08-15",
            "roles": ["USER"]
          }
        }
      }
    },
    {
      "feature": "Login (Get Token)",
      "method": "POST",
      "url": "/api/v1/auth/token",
      "auth": "Public",
      "requestBody": "AuthenticationRequest",
      "responsePayload": "AuthenticationResponse",
      "httpStatus": 200,
      "example": {
        "request": {
          "username": "johndoe",
          "password": "secret123"
        },
        "response": {
          "code": 1000,
          "message": "Success",
          "result": {
            "token": "eyJhbGciOiJIUzUxMiJ9...",
            "authenticated": true
          }
        }
      }
    },
    {
      "feature": "Introspect Token",
      "method": "POST",
      "url": "/api/v1/auth/introspect",
      "auth": "Public",
      "requestBody": "IntrospectRequest",
      "responsePayload": "IntrospectResponse",
      "httpStatus": 200,
      "example": {
        "request": {
          "token": "eyJhbGciOiJIUzUxMiJ9..."
        },
        "response": {
          "code": 1000,
          "message": "Success",
          "result": {
            "valid": true
          }
        }
      }
    },
    {
      "feature": "Get My Profile",
      "method": "GET",
      "url": "/api/v1/users/me",
      "auth": "USER",
      "requestBody": null,
      "responsePayload": "UserResponse",
      "httpStatus": 200,
      "headers": {
        "Authorization": "Bearer <token>"
      },
      "example": {
        "response": {
          "code": 1000,
          "message": "Success",
          "result": {
            "id": "a1b2c3d4",
            "username": "johndoe",
            "firstName": "John",
            "lastName": "Doe",
            "dob": "1995-08-15",
            "roles": ["USER"]
          }
        }
      }
    },
    {
      "feature": "Update My Profile",
      "method": "PUT",
      "url": "/api/v1/users/me",
      "auth": "USER",
      "requestBody": "UserUpdateRequest",
      "responsePayload": "UserResponse",
      "httpStatus": 200,
      "headers": {
        "Authorization": "Bearer <token>"
      },
      "example": {
        "request": {
          "password": "newpassword123",
          "firstName": "Johnny",
          "lastName": "Doe",
          "dob": "1995-08-15"
        },
        "response": {
          "code": 1000,
          "message": "Success",
          "result": {
            "id": "a1b2c3d4",
            "username": "johndoe",
            "firstName": "Johnny",
            "lastName": "Doe",
            "dob": "1995-08-15",
            "roles": ["USER"]
          }
        }
      }
    },
    {
      "feature": "Get All Users",
      "method": "GET",
      "url": "/api/v1/users",
      "auth": "ADMIN",
      "requestBody": null,
      "responsePayload": "List<UserResponse>",
      "httpStatus": 200,
      "headers": {
        "Authorization": "Bearer <token>"
      },
      "example": {
        "response": {
          "code": 1000,
          "message": "Success",
          "result": [
            {
              "id": "a1b2c3d4",
              "username": "johndoe",
              "firstName": "John",
              "lastName": "Doe",
              "dob": "1995-08-15",
              "roles": ["USER"]
            }
          ]
        }
      }
    },
    {
      "feature": "Get User by ID",
      "method": "GET",
      "url": "/api/v1/users/{id}",
      "auth": "ADMIN",
      "requestBody": null,
      "responsePayload": "UserResponse",
      "httpStatus": 200,
      "pathParams": {
        "id": "string (user UUID)"
      },
      "headers": {
        "Authorization": "Bearer <token>"
      },
      "example": {
        "response": {
          "code": 1000,
          "message": "Success",
          "result": {
            "id": "a1b2c3d4",
            "username": "johndoe",
            "firstName": "John",
            "lastName": "Doe",
            "dob": "1995-08-15",
            "roles": ["USER"]
          }
        }
      }
    },
    {
      "feature": "Delete User",
      "method": "DELETE",
      "url": "/api/v1/users/{id}",
      "auth": "ADMIN",
      "requestBody": null,
      "responsePayload": null,
      "httpStatus": 200,
      "pathParams": {
        "id": "string (user UUID)"
      },
      "headers": {
        "Authorization": "Bearer <token>"
      },
      "example": {
        "response": {
          "code": 1000,
          "message": "User deleted successfully",
          "result": null
        }
      }
    }
  ]
}
